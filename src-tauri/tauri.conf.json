{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "勾勾",
  "version": "0.1.0",
  "identifier": "com.ym0523lv.gougou",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "勾勾",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' gougou-asset: http://gougou-asset.localhost https://gougou-asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self'",
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
